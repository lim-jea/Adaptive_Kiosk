# 백엔드 환경변수 예시 — 복사 후 .env 로 이름 변경

# ─── 관리자 계정 (Swagger 문서 + 관리자 API) ───
KIOSK_USERNAME=your_admin_username
KIOSK_PASSWORD=your_admin_password

# ─── DB 연결 URL ───
# 로컬 MySQL:        mysql+aiomysql://your_user:your_password@127.0.0.1:3306/your_db
# Aiven Cloud:       mysql+aiomysql://your_user:your_password@your_host.aivencloud.com:your_port/defaultdb
# TiDB Cloud:        mysql+aiomysql://your_user:your_password@your_host.tidbcloud.com:4000/test
DATABASE_CONN=

# ─── Google Gemini API (음성 주문용, 2단계) ───
GENAI_API_KEY=your_google_genai_api_key
