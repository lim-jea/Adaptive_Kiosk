# 프론트엔드 환경변수 예시
# 복사 후 .env 로 이름 변경하여 사용

# 백엔드 API URL (로컬 개발: http://localhost:5000, 외부 시연: ngrok URL)
VITE_API_URL=http://localhost:5000

# 키오스크 인증용 API 키 (백엔드 시작 시 콘솔에 출력된 64자 hex)
# - seed_sample.py가 자동 생성한 "1층 로비 키오스크"의 api_key를 복사해 넣으세요.
# - 또는 POST /api/v1/kiosks 로 직접 등록 후 받은 키를 사용하세요.
VITE_KIOSK_API_KEY=

# AES-256-GCM 암호화 사용 여부 (현재 백엔드는 평문만 지원하므로 false 권장)
VITE_ENCRYPTION_ENABLED=false
